# ==============================================================================
# HotPlex Static Foundation (2026 Core Environment)
# ==============================================================================
# This image contains the 99% stable OS baseline and shared tools.
# It does NOT contain hotplexd, enabling massive caching for SDK stacks.
# ==============================================================================

# --- Stage 1: Shared Tools Collector ---
FROM debian:bookworm-slim AS tools-collector
ARG GITHUB_PROXY
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl wget ca-certificates xz-utils libatomic1 unzip && \
    rm -rf /var/lib/apt/lists/*
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "x86_64" ]; then BIN="websocat.x86_64-unknown-linux-musl"; \
    elif [ "$ARCH" = "aarch64" ]; then BIN="websocat.aarch64-unknown-linux-musl"; fi && \
    curl -sSfL -o /usr/local/bin/websocat \
    "https://github.com/vi/websocat/releases/download/v1.14.1/$BIN" && \
    chmod +x /usr/local/bin/websocat

# --- Stage 2: AI Tools Collector ---
FROM node:24-bookworm-slim AS ai-tools-collector
ARG NPM_MIRROR

# 1. Install Claude Code (official installer)
RUN curl -fsSL https://claude.ai/install.sh | bash

# 2. Install OpenCode (official installer)
RUN curl -fsSL https://raw.githubusercontent.com/opencode-ai/opencode/refs/heads/main/install | bash

# 3. Install PI Coding Agent (npm fallback)
RUN npm install -g @mariozechner/pi-coding-agent && \
    npm cache clean --force

# --- Final Stage: Shared Foundation ---
FROM debian:bookworm-slim

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG DEBIAN_MIRROR
ARG HOST_UID=1000
ARG GITHUB_PROXY

# 1. Global OS Baseline & Mirrors
RUN if [ "$DEBIAN_MIRROR" != "deb.debian.org" ] && [ -n "$DEBIAN_MIRROR" ]; then \
        sed -i "s/deb.debian.org/$DEBIAN_MIRROR/g" /etc/apt/sources.list.d/debian.sources; \
    fi && \
    apt-get update && apt-get install -y --no-install-recommends \
    curl wget ca-certificates git make bash jq gettext-base \
    procps netcat-openbsd openssl libatomic1 unzip gnupg \
    python3 python3-pip python3-venv \
    zoxide bash-completion vim \
    && curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# 2. Multi-Architecture Binary Tools (gh, lazygit)
RUN bash -c 'set -o pipefail && \
    arch=$(uname -m) && \
    case "$arch" in \
        x86_64) gh_arch="amd64"; lg_arch="x86_64" ;; \
        aarch64) gh_arch="arm64"; lg_arch="arm64" ;; \
    esac && \
    # Install GitHub CLI (gh)
    gh_version="2.63.0" && \
    gh_url="https://github.com/cli/cli/releases/download/v${gh_version}/gh_${gh_version}_linux_${gh_arch}.tar.gz" && \
    (curl -sSL "${GITHUB_PROXY}${gh_url}" || curl -sSL "${gh_url}") | tar xz -C /tmp && \
    mv /tmp/gh_${gh_version}_linux_${gh_arch}/bin/gh /usr/local/bin/ && \
    rm -rf /tmp/gh_${gh_version}_linux_${gh_arch} && \
    # Install lazygit
    lg_version=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po "\"tag_name\": \"v\\K[^\"]*" || echo "0.60.0") && \
    lg_url="https://github.com/jesseduffield/lazygit/releases/download/v${lg_version}/lazygit_${lg_version}_linux_${lg_arch}.tar.gz" && \
    (curl -sSL -o lazygit.tar.gz "${GITHUB_PROXY}${lg_url}" || curl -sSL -o lazygit.tar.gz "${lg_url}") && \
    tar xf lazygit.tar.gz lazygit && \
    install lazygit /usr/local/bin && \
    rm lazygit.tar.gz lazygit'
    
# Install uv (Python), bun & pnpm (Node)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv
RUN npm install -g pnpm@latest bun@latest && \
    npm cache clean --force

# Pre-install notebooklm-py CLI (for NotebookLM skill)
# Browser support requires local GUI - container uses CLI mode only
RUN pip3 install --break-system-packages "notebooklm-py" && \
    rm -rf /root/.cache/pip /root/.cache/uv

# 2. HotPlex User & Workspace Setup
RUN useradd -m -u ${HOST_UID} -s /bin/bash hotplex && \
    mkdir -p /app /home/hotplex/.cache && \
    chown -R hotplex:hotplex /home/hotplex /app

# Inject custom shell environment
COPY docker/bashrc.hotplex /home/hotplex/.bashrc
RUN chown hotplex:hotplex /home/hotplex/.bashrc

# 3. Static Tool Injection
# Copy websocat from tools-collector
COPY --from=tools-collector /usr/local/bin/websocat /usr/local/bin/websocat
# Claude Code is already installed via curl installer in Stage 2
# Install additional npm tools (opencode-ai, pi-coding-agent)
RUN npm install -g opencode-ai @mariozechner/pi-coding-agent && \
    npm cache clean --force && \
    # Create symlinks for npm tools
RUN ln -sf /usr/local/lib/node_modules/opencode-ai/bin/opencode /usr/local/bin/opencode && \
    ln -sf /usr/local/lib/node_modules/@mariozechner/pi-coding-agent/dist/cli.js /usr/local/bin/pi

# 4. Standard Metadata & Entrypoint
WORKDIR /app
COPY docker/docker-entrypoint.sh /app/docker-entrypoint.sh
RUN chmod +x /app/docker-entrypoint.sh
ENV PATH="/usr/local/bin:${PATH}"

ENTRYPOINT ["/app/docker-entrypoint.sh"]
# default CMD (can be overridden by stacks)
CMD ["bash"]

LABEL org.opencontainers.image.vendor="HotPlex"
LABEL org.opencontainers.image.title="HotPlex Foundation (Static)"

# Main server port (WebSocket/HTTP)
EXPOSE 8080
# Admin API port
EXPOSE 8081
